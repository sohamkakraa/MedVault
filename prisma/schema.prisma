generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  phoneE164   String?  @unique @map("phone_e164")
  googleId    String?  @unique @map("google_id")
  googleEmail String?  @map("google_email")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  whatsappPhone    String?  @unique @map("whatsapp_phone")
  whatsappVerified Boolean  @default(false) @map("whatsapp_verified")

  /**
   * The thread that incoming WhatsApp messages and the webapp chat both write
   * into by default. Switching threads in the webapp updates this field, so
   * the next WA message lands in the same conversation the user is reading on
   * the web — that is the "WA chat is the default view, switching syncs both
   * sides" requirement. Null means "lazily create a default thread on next use".
   */
  activeThreadId   String?  @map("active_thread_id")

  patientRecord    PatientRecord?
  whatsappMessages WhatsAppMessage[]
  whatsappPrefs    WhatsAppPreferences?
  wellnessLogs     WellnessLog[]
  threads          Thread[]
  messages         Message[]
  waterLogs        WaterLog[]
}

/**
 * Per-user WhatsApp preferences — communication style, check-in schedule,
 * and learned personality traits so UMA mirrors how the user likes to chat.
 */
model WhatsAppPreferences {
  userId             String  @id @map("user_id")
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// "casual", "detailed", "brief", etc. — inferred from chat patterns
  communicationStyle String? @map("communication_style")
  /// "simple" (no jargon), "moderate", "technical"
  languageLevel      String? @default("simple") @map("language_level")
  /// What the user prefers to be called
  preferredName      String? @map("preferred_name")
  /// Daily check-in time in HH:mm (24h) format, user's local time
  checkinTime        String? @map("checkin_time")
  /// Whether daily check-ins are enabled
  checkinEnabled     Boolean @default(false) @map("checkin_enabled")
  /// IANA timezone, e.g. "Asia/Kolkata"
  timezone           String? @default("Asia/Kolkata")
  /// Last time a daily check-in was sent (prevents duplicates)
  lastCheckinSentAt  DateTime? @map("last_checkin_sent_at")

  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("whatsapp_preferences")
}

/**
 * Structured wellness log entries — mood, energy, symptoms, medication adherence.
 * Populated from WhatsApp check-in conversations.
 */
model WellnessLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Date of the log entry (one per day typically)
  logDate     DateTime @map("log_date") @db.Date
  /// 1-5 scale: 1=very low, 5=great
  mood        Int?
  /// 1-5 scale: 1=exhausted, 5=energetic
  energy      Int?
  /// Free-text symptoms mentioned
  symptoms    String?  @db.Text
  /// Did they take their meds? true/false/null(not asked)
  medsTaken   Boolean? @map("meds_taken")
  /// Raw user message that produced this log
  rawMessage  String?  @map("raw_message") @db.Text
  /// Any additional notes extracted by the LLM
  notes       String?  @db.Text

  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, logDate])
  @@index([userId, logDate])
  @@map("wellness_logs")
}

model WhatsAppMessage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  waId      String   @map("wa_id")
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([waId, createdAt])
  @@map("whatsapp_messages")
}

model OtpChallenge {
  id        String   @id @default(cuid())
  lookupKey String   @unique @map("lookup_key")
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
}

model PatientRecord {
  userId    String   @id @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")
}

/**
 * Database-backed rate limit counter (VULN-007).
 * Replaces the in-memory Map which resets on every serverless cold start.
 * Each row tracks a sliding window per key (e.g. "otp:1.2.3.4").
 */
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  windowEnd DateTime @map("window_end")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("rate_limits")
}

/** Demo / wiring table (Neon tutorial parity); not part of core health data flows. */
model Comment {
  id        String   @id @default(cuid())
  comment   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("comments")
}

/**
 * Idempotency guard for incoming WhatsApp messages.
 * Created inside a transaction before processIncomingMessage runs.
 * A duplicate messageId → row already exists → skip processing.
 */
model WhatsAppDelivery {
  eId        String   @id @map("e_id")
  receivedAt DateTime @default(now()) @map("received_at")

  @@map("whatsapp_deliveries")
}

/**
 * One-time token sent to an unknown WhatsApp sender so they can
 * complete sign-up via the web login page (`?wa=<token>`).
 * Consumed on success; expires after 15 minutes.
 */
model PendingLink {
  token     String   @id
  phoneE164 String   @map("phone_e164")
  expiresAt DateTime @map("expires_at")

  @@map("pending_links")
}

/**
 * A conversation thread. The same Thread is shared between the webapp chat
 * page and the WhatsApp surface — when the user switches threads in the
 * webapp, `User.activeThreadId` is updated and the next incoming WhatsApp
 * message lands in the same thread. There is no per-channel partitioning;
 * messages just carry a `source` field describing where they came from.
 *
 * Soft-delete is `archivedAt`. Threads are never hard-deleted so the user
 * can always recover an old conversation.
 */
model Thread {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /**
   * Display title. Falls back to a synthesized "Chat from <date>" in the UI
   * when null. We compute a title automatically from the first user message
   * a few turns in.
   */
  title         String?
  archivedAt    DateTime? @map("archived_at")
  /**
   * lastMessageAt is denormalized so thread-list reads don't need a JOIN +
   * aggregate every time the sidebar loads. Updated on every Message append.
   */
  lastMessageAt   DateTime  @default(now()) @map("last_message_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  /**
   * Caveman-compressed summary of older messages in this thread. Stored so
   * we don't re-summarize on every request. Updated asynchronously after
   * every 5 new messages once the thread has more than CAVEMAN_THRESHOLD turns.
   */
  contextSummary  String?   @map("context_summary") @db.Text

  messages Message[]

  @@index([userId, archivedAt, lastMessageAt(sort: Desc)])
  @@map("threads")
}

/**
 * Single message inside a thread. Source field tracks origin so the UI can
 * show a small chip ("from WhatsApp") when a thread mixes channels.
 *
 * `waMessageId` is the Meta-supplied id; we keep it so the WhatsApp idempotency
 * guard (WhatsAppDelivery) and the message log stay cross-referenceable.
 */
model Message {
  id          String   @id @default(cuid())
  threadId    String   @map("thread_id")
  thread      Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// "user" or "assistant" — matches Anthropic message roles.
  role        String
  content     String   @db.Text
  /// "web", "whatsapp", or "system" (e.g. cron-sent reminders).
  source      String   @default("web")
  waMessageId String?  @map("wa_message_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([threadId, createdAt])
  @@index([userId, createdAt])
  @@map("messages")
}

/**
 * One logged water intake event. Written each time the user tells UMA they
 * finished a bottle on WhatsApp ("done", "had water", etc.) or via the chat
 * intent classifier. The amount defaults to the reminder's bottle_ml if set.
 */
model WaterLog {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMl Int      @default(800) @map("amount_ml")
  notes    String?  @db.Text
  loggedAt DateTime @default(now()) @map("logged_at")

  @@index([userId, loggedAt])
  @@map("water_logs")
}
